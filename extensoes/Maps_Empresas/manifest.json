{
  "manifest_version": 3,
  "name": "Maps_Empresas",
  "version": "1.0.0",
  "description": "Extensão local para captura assistida de dados visíveis de empresas no Google Maps.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://www.google.com.br/maps/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*",
        "https://www.google.com.br/maps/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
