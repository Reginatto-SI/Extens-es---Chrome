{
  "manifest_version": 3,
  "name": "Central Inteligente do Escritório",
  "version": "1.0.0",
  "description": "Hub interno flexível para organizar dados, acessos e rotinas do escritório.",
  "permissions": ["storage", "tabs", "clipboardWrite"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Central Inteligente do Escritório"
  },
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "web_accessible_resources": [
    {
      "resources": ["app.html", "app.css", "app.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
